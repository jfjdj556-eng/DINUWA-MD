# Your WhatsApp number, digits only, with country code (no + sign)
PHONE_NUMBER=947XXXXXXXX

# Command prefix
PREFIX=.

# Bot display name
BOT_NAME=DINUWA MD

# Your name
OWNER_NAME=Owner

# Your WhatsApp number (digits only, with country code, no +).
# Only this number can use .setemoji, .addchannel, .removechannel, .broadcast
OWNER_NUMBER=947XXXXXXXX

# Default emoji used when auto-reacting to watched channel posts
DEFAULT_REACT_EMOJI=❤️

# Port for the built-in pairing website (only used until you pair once)
PORT=3000

# OPTIONAL: paste the session string you got from the pairing website here
# so the bot logs in automatically without asking for a pairing code again.
SESSION=
